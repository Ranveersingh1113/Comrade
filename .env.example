# Comrade — environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- LLM (Google Gemini: primary Flash + escalation Pro) ---
GEMINI_API_KEY=

# --- Embeddings (OpenAI text-embedding-3-small) ---
OPENAI_API_KEY=

# --- Supabase (Postgres + pgvector + Realtime + Auth + Storage) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Scoped role key used by the MCP server / pipeline. NEVER use service_role at runtime.
SUPABASE_SECRET_KEY=

# --- GitHub MCP server (fine-grained PAT, scoped to pilot repos only) ---
GITHUB_PAT=

# --- Direct Postgres connections (RLS-enforced; never service_role) ---
# Admin role — used ONLY by tests to seed/clean (bypasses RLS as owner).
COMRADE_DB_URL_ADMIN=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Worker roles — team-scoped via SET LOCAL app.current_team_id, RLS enforced.
COMRADE_AGENT_DB_URL=postgresql://comrade_agent:CHANGE_ME@127.0.0.1:54322/postgres
COMRADE_EXECUTOR_DB_URL=postgresql://comrade_executor:CHANGE_ME@127.0.0.1:54322/postgres
COMRADE_PIPELINE_DB_URL=postgresql://comrade_pipeline:CHANGE_ME@127.0.0.1:54322/postgres
